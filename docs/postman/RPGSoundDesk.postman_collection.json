{
  "info": {
    "name": "RPGSoundDesk API",
    "_postman_id": "rpgsounddesk-local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/health"
      }
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"gm@demo.com\",\"display_name\":\"GM\",\"password\":\"StrongPass123\",\"organization_id\":\"org-demo\",\"role\":\"admin\"}"
        },
        "url": "{{baseUrl}}/api/v1/auth/register"
      }
    },
    {
      "name": "Auth - Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"gm@demo.com\",\"password\":\"StrongPass123\",\"organization_id\":\"org-demo\"}"
        },
        "url": "{{baseUrl}}/api/v1/auth/token"
      }
    },
    {
      "name": "Tables - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Mesa Postman\"}"
        },
        "url": "{{baseUrl}}/api/v1/tables"
      }
    },
    {
      "name": "Players - Add",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"display_name\":\"Luna\"}"
        },
        "url": "{{baseUrl}}/api/v1/tables/{{tableId}}/players"
      }
    },
    {
      "name": "Players - Update Availability",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"availability\":\"red\"}"
        },
        "url": "{{baseUrl}}/api/v1/tables/{{tableId}}/players/{{playerId}}"
      }
    },
    {
      "name": "SoundEvents - Schedule",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"table_id\":\"{{tableId}}\",\"session_id\":\"session-1\",\"action\":\"play:battle\",\"execute_at\":\"2026-01-01T00:00:05Z\"}"
        },
        "url": "{{baseUrl}}/api/v1/sound-events"
      }
    },
    {
      "name": "Audit - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/audit/{{orgId}}"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8010" },
    { "key": "orgId", "value": "org-demo" },
    { "key": "token", "value": "" },
    { "key": "tableId", "value": "" },
    { "key": "playerId", "value": "" }
  ]
}

